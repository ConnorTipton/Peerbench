# Peerbench web — local env template.
# Copy to .env.local and fill in real values from Supabase Project Settings → API.
# Production values for these vars live in the Vercel project (Settings → Environment Variables).

# Supabase (anon key only — service role NEVER goes in the web layer).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (DSN is a public token; safe to expose to the client).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Sentry source-map upload (set in Vercel only; local build skips upload without it).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
