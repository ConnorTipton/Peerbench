# ============================================================
# Peerbench — environment variable template
#
# Setup:  cp .env.example .env.local  and fill in real values.
# .env.local is gitignored; never commit real keys.
#
# In production:
#   - Frontend vars (NEXT_PUBLIC_*) live in Vercel project settings
#   - Pipeline vars live in GitHub Actions repo secrets
# ============================================================

# --- FDIC BankFind API ---
# Optional. Register at https://api.fdic.gov for rate-limit headroom.
FDIC_API_KEY=

# --- Supabase (pipeline) ---
# From Supabase: Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# DANGER: service role bypasses RLS. Pipeline-only. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for SQLAlchemy + weekly pg_dump backups.
# From Supabase: Database → Connection string → URI. Use the session pooler.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# --- Supabase (Next.js frontend) ---
# NEXT_PUBLIC_* values are exposed to the browser. Only the anon key goes here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry (Phase 3) ---
# From Sentry: Project Settings → Client Keys (DSN).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
